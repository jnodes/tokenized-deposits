# =============================================================================
# Cari Orchestrator — Environment Configuration
# Copy to .env and fill in production values.
# =============================================================================

# --- App ---
CARI_ENVIRONMENT=dev
CARI_DEBUG=true
CARI_API_PREFIX=/api/v1

# --- ZKsync Prividium ---
CARI_PRIVIDIUM_RPC_URL=https://sepolia.era.zksync.dev
CARI_CHAIN_ID=300
CARI_TOKEN_CONTRACT_ADDRESS=
CARI_ORACLE_CONTRACT_ADDRESS=
CARI_SETTLEMENT_CONTRACT_ADDRESS=
CARI_COMPLIANCE_ORACLE_ADDRESS=

# --- Signing (LOCAL DEV ONLY — use HSM in production) ---
CARI_MINTER_PRIVATE_KEY=
CARI_BURNER_PRIVATE_KEY=
CARI_ATTESTOR_PRIVATE_KEY=
CARI_COMPLIANCE_PRIVATE_KEY=
CARI_SETTLEMENT_PRIVATE_KEY=

# --- HSM (Production) ---
CARI_HSM_PROVIDER=
CARI_HSM_KEY_ID_MINTER=
CARI_HSM_KEY_ID_BURNER=
CARI_HSM_KEY_ID_ATTESTOR=

# --- Core Banking ---
CARI_CORE_BANKING_BASE_URL=https://corebanking.internal.mtb.com/api
CARI_CORE_BANKING_API_KEY=

# --- Custody ---
CARI_FIREBLOCKS_API_KEY=
CARI_FIREBLOCKS_API_SECRET_PATH=
CARI_FIREBLOCKS_VAULT_ID=
CARI_COINBASE_CUSTODY_API_KEY=

# --- Kafka ---
CARI_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
CARI_KAFKA_TOPIC_TRANSACTIONS=cari.transactions
CARI_KAFKA_TOPIC_COMPLIANCE=cari.compliance
CARI_KAFKA_TOPIC_SETTLEMENTS=cari.settlements

# --- Redis ---
CARI_REDIS_URL=redis://localhost:6379/0

# --- Compliance ---
CARI_CHAINALYSIS_API_KEY=
CARI_NOTABENE_API_KEY=
CARI_TRAVEL_RULE_THRESHOLD_USD=3000

# --- Reserve Oracle ---
CARI_RESERVE_STALENESS_SECONDS=86400
CARI_RESERVE_REBALANCE_THRESHOLD_PCT=5.0

# --- Database ---
CARI_DATABASE_URL=sqlite+aiosqlite:///./cari_orchestrator.db
